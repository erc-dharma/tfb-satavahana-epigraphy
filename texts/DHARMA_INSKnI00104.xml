         <div type="edition" xml:lang="pra-Latn" rendition="class:83225 maturity:83209">
             <p><lb n="1"/>therānaṁ bhayatabudhatātānaṁ <space quantity="1" unit="character"/> Atevāsisa bhayatasihasa <space quantity="1" unit="character"/> deyadhamaṁ payapaṭo mahācetiE <space quantity="1" unit="character"/> saha <space quantity="1" unit="character"/> <unclear>Ac</unclear><supplied reason="lost">ā</supplied><unclear>r</unclear><supplied reason="lost">i</supplied><lb n="2" break="no"/>yaUpajh<unclear>āE</unclear><supplied reason="lost">h</supplied>i <supplied reason="lost">sa</supplied><unclear>ha</unclear> mātāpit<unclear>ūhi</unclear> <space quantity="1" unit="character"/> saha va savehi <space quantity="1" unit="character"/> Atevāsikehi <space quantity="1" unit="character"/> savasatāna <space quantity="1" unit="character"/> hitasughāvāhāya <g ref="sym:doubleBar" type="punctuation">.</g><g ref="sym:doubleBar" type="punctuation">.</g></p>
         </div>
