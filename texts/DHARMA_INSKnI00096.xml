                 </app>
                 <app loc="3">
                     <lem>golā<supplied reason="omitted">A</supplied> ca</lem>
                     <note><bibl><ptr target="bib:Nakanishi+Hinuber2014_01"/></bibl> suggest instead that <foreign>ca</foreign> and <foreign>ya</foreign> might be confused here as in <ref target="DHARMA_INSKnI00116.xml">KnI 116</ref>.</note>
                 </app>
