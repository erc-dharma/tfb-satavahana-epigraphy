         <div type="edition" xml:lang="pra-Latn" rendition="class:83225 maturity:83209">
             <p><lb n="1"/>sidha <g ref="sym:doubleBar" type="punctuation">.</g> namo bhagavato budhasa <space/> bhikhusa <space/> budhikayasa <space/> chataṁ deyadhamaṁ <lb n="2"/>sahā mātāpitūhi <lb n="3"/>sahā ca bhaginihi golā<supplied reason="omitted">A</supplied> ca bodhiA ca sava<add place="below">lo</add>kahitāya</p>
         </div>
         <div type="apparatus">
             <listApp>
                 <app loc="1">
