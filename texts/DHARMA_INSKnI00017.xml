         <div type="edition" xml:lang="pra-Latn" rendition="class:83225 maturity:83209">
             <p>
                 <lb n="1"/><supplied reason="lost">sidha <g ref="sym:bar" type="punctuation">.</g> korugālakāna</supplied> AcariĀna bhayatasatikaṇa <space/> Atevāsiniya <unclear>pa</unclear>vaIt<unclear>ā</unclear>ya <unclear>b</unclear>udharakhitāya <space/> Ayākapaṭā <space/> Adh<unclear>ā</unclear>lakacetiyadhamaraIka<space/>deyadhama patiṭhāpit<unclear>ā t</unclear><supplied reason="lost">i</supplied>
             </p>
         </div>
         <div type="apparatus">
             <listApp>
                 <app loc="1">
                     <lem>bhayatasatikaṇa</lem>
                     <rdg source="bib:Nakanishi+Hinuber2014_01">bhayata sat<unclear>ikana</unclear></rdg>
                     <note>Read <foreign>-kana</foreign>, as in <ref target="DHARMA_INSEIAD00018">KnI0018</ref>.</note>
                 </app>
                 <app loc="1">
                     <lem><unclear>pa</unclear>vaIt<unclear>ā</unclear>ya</lem>
                     <rdg source="bib:Nakanishi+Hinuber2014_01"><unclear>pa</unclear>vajit<unclear>ā</unclear>ya</rdg>
                 </app>
                 <app loc="1">
                     <lem>Adh<unclear>ā</unclear>laka-</lem>
                     <note>Could be read aṃdhalaka.</note>
                 </app>
                 <app loc="1">
                     <lem>-dhamaraIka-</lem>
                     <rdg source="bib:Nakanishi+Hinuber2014_01">-dhamarajaka</rdg>
                     <note><bibl><ptr target="bib:Tournier2020_02"/></bibl> understands this as forming a compound with the following <foreign>deyadhama</foreign>, but <foreign>-dhamaraIka</foreign> could also be understood as un uninflected locative.</note>
                 </app>
                 <app loc="1">
                     <lem>patiṭhāpit<unclear>ā t</unclear><supplied reason="lost">i</supplied></lem>
